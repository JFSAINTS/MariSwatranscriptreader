# Environment variables for MariSwa PDF Reader
# Copy this file to .env.local and fill in your values

# Optional: Google Cloud Vision API (for future image recognition)
# VITE_GOOGLE_VISION_API_KEY=your_api_key_here

# Optional: Firebase Configuration (if using backend sync)
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
